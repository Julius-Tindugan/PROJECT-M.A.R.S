# Backend Production Environment Template
# Copy this to backend/.env when deploying to Render

APP_NAME="Your Web App"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-backend-app.onrender.com

# Database Configuration (Use Neon.tech free PostgreSQL)
# Get these from https://neon.tech dashboard
DB_CONNECTION=pgsql
DB_HOST=ep-abc123.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neon_user
DB_PASSWORD=your_secure_password_here

# Add this via Render UI: go to Service → Environment
# Laravel will generate this for you with: php artisan key:generate
APP_KEY=base64:YOUR_BASE64_ENCODED_KEY

# Cache & Session (use simpler options for free tier)
CACHE_DRIVER=database
SESSION_DRIVER=cookie
QUEUE_CONNECTION=sync

# Mail (optional - use dummy driver for free tier)
MAIL_DRIVER=log
MAIL_FROM_NAME="${APP_NAME}"
MAIL_FROM_ADDRESS=noreply@example.com

# Optional services
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
